{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",
  "schedule": ["every weekday", "on saturday"],

  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^versions/unbound\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "fileMatch": ["^versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+\\-[0-9]+)$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "madnuttah/openssl-buildenv",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "fileMatch": ["^versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+\\-[0-9]+)\\-quic$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "madnuttah/openssl-buildenv",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "fileMatch": ["^versions/unbound-docker-image\\.txt$"],
      "matchStrings": [
        "unbound=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^versions/unbound-docker-image\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-unbound-subversion",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "fileMatch": ["^versions/unbound-quic-docker-image\\.txt$"],
      "matchStrings": [
        "unbound=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^versions/unbound-quic-docker-image\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-unbound-quic-subversion",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },

    {
      "matchFileNames": ["versions/unbound-docker-image.txt"],
      "matchDepNames": ["dummy-unbound-subversion"],
      "semanticCommitType": "fix"
    },
    {
      "matchFileNames": ["versions/unbound-quic-docker-image.txt"],
      "matchDepNames": ["dummy-unbound-quic-subversion"],
      "semanticCommitType": "fix"
    }
  ]
}