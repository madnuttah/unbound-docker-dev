{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",
  "schedule": ["at any time"],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/unbound\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/unbound-sha256\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[a-f0-9]{64})$"
      ],
      "datasourceTemplate": "github-release-attachments",
      "depNameTemplate": "NLnetLabs/unbound",
      "extractVersionTemplate": "versions/unbound.txt",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]+)$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "madnuttah/openssl-buildenv",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-quic\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]+-quic)$"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^(?<version>[0-9]+\\.[0-9]+\\.[0-9]+-[0-9]+)-quic$",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl.txt"],
      "matchDepNames": ["madnuttah/openssl-buildenv"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchFileNames": ["versions/openssl-quic.txt"],
      "matchDepNames": ["madnuttah/openssl-buildenv"],
      "allowedVersions": "<4.0.0"
    }
  ]
}
