{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["every weekday", "on saturday"],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)versions/unbound\\.txt$/"
      ],
      "matchStrings": [
        "(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "unbound",
      "packageNameTemplate": "NLnetLabs/unbound",
      "extractVersionTemplate": "^release-(?<version>.*)$",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)versions/openssl-buildenv\\.txt$/"
      ],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl-buildenv",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)versions/openssl-buildenv\\.txt$/"
      ],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-openssl-subversion",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)versions/openssl-quic-buildenv\\.txt$/"
      ],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl-quic-buildenv",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)versions/openssl-quic-buildenv\\.txt$/"
      ],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-quic-subversion",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },

    {
      "description": "Increment OpenSSL buildenv subversion on dependency changes",
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "matchDepNames": ["dummy-openssl-subversion"],
      "semanticCommitType": "fix"
    },
    {
      "description": "Increment QUIC subversion on dependency changes",
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "matchDepNames": ["dummy-quic-subversion"],
      "semanticCommitType": "fix"
    }
  ]
}
