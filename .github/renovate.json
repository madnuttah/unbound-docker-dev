{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "every weekday",
    "on saturday"
  ],

"customManagers": [
  {
    "enabled": true,
    "customType": "regex",
    "managerFilePatterns": [
      "versions/unbound\\.txt$"
    ],
    "matchStrings": [
      "^(?<currentValue>\\d+\\.\\d+\\.\\d+)\\s*$"
    ],
    "datasourceTemplate": "github-tags",
    "packageNameTemplate": "NLnetLabs/unbound",

    // stable only
    "extractVersionTemplate": "^release-(?<version>\\d+\\.\\d+\\.\\d+)$",

    "versioningTemplate": "semver"
  },
  {
    "enabled": true,
    "customType": "regex",
    "managerFilePatterns": [
      "versions/openssl-buildenv\\.txt$"
    ],
    "matchStrings": [
      "^OPENSSL_BUILDENV_VERSION=(?<currentValue>[^\\s]+)"
    ],
    "datasourceTemplate": "github-releases",
    "packageNameTemplate": "madnuttah/openssl-buildenv",
    "extractVersionTemplate": "^v(?<version>.*)$",
    "versioningTemplate": "loose"
  },
  {
    "enabled": true,
    "customType": "regex",
    "managerFilePatterns": [
      "versions/openssl-quic-buildenv\\.txt$"
    ],
    "matchStrings": [
      "^OPENSSL_QUIC_BUILDENV_VERSION=(?<currentValue>[^\\s]+)"
    ],
    "datasourceTemplate": "github-releases",
    "packageNameTemplate": "madnuttah/openssl-buildenv",
    "extractVersionTemplate": "^v(?<version>.*)$",
    "versioningTemplate": "loose"
  }
],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    }
  ]
}
