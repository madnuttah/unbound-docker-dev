{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",
  "schedule": ["every weekday", "on saturday"],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/unbound\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-openssl-subversion",
      "versioningTemplate": "semver"
    },

    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "sub=(?<currentValue>[0-9]+)"
      ],
      "datasourceTemplate": "npm",
      "depNameTemplate": "dummy-quic-subversion",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },

    {
      "matchFileNames": ["versions/unbound.txt"],
      "matchDepNames": ["NLnetLabs/unbound"],
      "allowedVersions": "<2.0.0"
    },

    {
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0",
      "semanticCommitType": "fix"
    },
    {
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0",
      "semanticCommitType": "fix"
    },

    {
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "matchDepNames": ["dummy-openssl-subversion"],
      "semanticCommitType": "fix"
    },
    {
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "matchDepNames": ["dummy-quic-subversion"],
      "semanticCommitType": "fix"
    }
  ]
}
