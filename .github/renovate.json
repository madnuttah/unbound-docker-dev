{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",

  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],

  "timezone": "Europe/Berlin",
  "schedule": ["at any time"],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/unbound\\.txt$"],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)$"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "NLnetLabs/unbound",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["^versions/openssl-quic-buildenv\\.txt$"],
      "matchStrings": [
        "openssl=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+[a-z]?)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "openssl",
      "packageNameTemplate": "openssl/openssl",
      "versioningTemplate": "semver"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    },
    {
      "matchFileNames": ["versions/openssl-buildenv.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0",
      "labels": ["bump-openssl-subversion"]
    },
    {
      "matchFileNames": ["versions/openssl-quic-buildenv.txt"],
      "matchDepNames": ["openssl"],
      "allowedVersions": "<4.0.0",
      "labels": ["bump-quic-subversion"]
    }
  ]
}