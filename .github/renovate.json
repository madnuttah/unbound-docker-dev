{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "config:best-practices",
    ":semanticCommitsDisabled",
    ":automergeStableNonMajor",
    ":automergePatch",
    ":automergeDigest",
    "group:allDigest"
  ],
  "timezone": "Europe/Berlin",
  "schedule": [
    "every weekday",
    "on saturday"
  ],

  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "versions/unbound\\.txt$"
      ],
      "matchStrings": [
        "^(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\\n$"
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "NLnetLabs/unbound",
      "extractVersionTemplate": "^release-(?<version>.*)$",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "versions/openssl-buildenv\\.txt$"
      ],
      "matchStrings": [
        "^OPENSSL_BUILDENV_VERSION=(?<currentValue>.*)\\n$"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "versions/openssl-quic-buildenv\\.txt$"
      ],
      "matchStrings": [
        "^OPENSSL_QUIC_BUILDENV_VERSION=(?<currentValue>.*)\\n$"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "madnuttah/openssl-buildenv",
      "extractVersionTemplate": "^v(?<version>.*)$",
      "versioningTemplate": "loose"
    }
  ],

  "packageRules": [
    {
      "matchManagers": ["dockerfile"],
      "enabled": false
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true,
      "automerge": true
    }
  ]
}
